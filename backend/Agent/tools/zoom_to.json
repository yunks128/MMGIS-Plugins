{
  "name": "zoom_to",
  "description": "Zoom to lon/lat and zoom level, or to a bbox.",
  "parameters": {
    "type": "object",
    "oneOf": [
      {
        "type": "object",
        "properties": {
          "center": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 2,
            "maxItems": 2,
            "description": "[lon,lat]"
          },
          "zoom": {
            "type": "integer",
            "minimum": 0,
            "maximum": 22,
            "default": 15
          }
        },
        "required": ["center", "zoom"],
        "additionalProperties": false
      },
      {
        "type": "object",
        "properties": {
          "bbox": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 4,
            "maxItems": 4,
            "description": "[minLon,minLat,maxLon,maxLat]"
          }
        },
        "required": ["bbox"],
        "additionalProperties": false
      }
    ]
  },
  "modelParameters": {
    "type": "object",
    "properties": {
      "center": {
        "type": "array",
        "items": { "type": "number" },
        "minItems": 2,
        "maxItems": 2
      },
      "zoom": { "type": "integer" },
      "bbox": {
        "type": "array",
        "items": { "type": "number" },
        "minItems": 4,
        "maxItems": 4
      }
    },
    "additionalProperties": false
  },
  "execution": {
    "adapter": "custom",
    "name": "zoom_to",
    "ui": { "type": "zoom_view" }
  }
}
